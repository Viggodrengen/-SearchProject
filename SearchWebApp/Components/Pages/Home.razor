@page "/"
@rendermode InteractiveServer
@inject SearchWebApp.Interfaces.ISearchApiClient ApiClient

<PageTitle>Søg</PageTitle>

<h1>Dokumentsøgning</h1>

<div class="mb-3">
    <label class="form-label">Søgetermer</label>
    <input class="form-control" @bind="Query" placeholder="fx machine learning notes" />
</div>

<div class="row g-3 mb-3">
    <div class="col-sm-4">
        <label class="form-label">Database</label>
        <select class="form-select" @bind="Database">
            <option value="sqlite">SQLite</option>
            <option value="postgres">Postgres</option>
        </select>
    </div>
    <div class="col-sm-4">
        <label class="form-label">Maks. antal resultater</label>
        <input class="form-control" type="number" min="1" max="100" @bind="MaxAmount" />
    </div>
    <div class="col-sm-4 d-flex align-items-end">
        <div class="form-check">
            <input id="caseSensitive" class="form-check-input" type="checkbox" @bind="CaseSensitive" />
            <label class="form-check-label" for="caseSensitive">Case-sensitive</label>
        </div>
    </div>
</div>

<div class="d-flex gap-2 align-items-center">
    <button class="btn btn-primary" @onclick="PerformSearchAsync" disabled="@IsSearching">
        @(IsSearching ? "Søger..." : "Søg")
    </button>
    <button class="btn btn-outline-warning" @onclick="ClearCacheAsync" disabled="@(IsSearching || IsClearingCache)">
        @(IsClearingCache ? "Rydder cache..." : "Ryd cache")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(CacheMessage))
{
    <div class="alert alert-info mt-3">@CacheMessage</div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@if (SearchResult is not null)
{
    <div class="mt-4">
        <p><strong>Dokumenter:</strong> @SearchResult.NoOfHits</p>
        <p><strong>Tid:</strong> @SearchResult.TimeUsed.TotalMilliseconds ms</p>
        @if (!string.IsNullOrWhiteSpace(Backend))
        {
            <p><strong>Serveret af:</strong> @Backend (@Strategy) [@SearchApiInstance]</p>
        }
        @if (!string.IsNullOrWhiteSpace(CacheStatus))
        {
            <p><strong>Cache:</strong> @CacheStatus</p>
        }
        @if (SearchResult.Ignored.Count > 0)
        {
            <p><strong>Ignoreret:</strong> @string.Join(", ", SearchResult.Ignored)</p>
        }
    </div>

    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>#</th>
                <th>URL</th>
                <th>Hits</th>
                <th>Indekseret</th>
                <th>Mangler</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < SearchResult.DocumentHits.Count; i++)
            {
                var hit = SearchResult.DocumentHits[i];
                <tr>
                    <td>@(i + 1)</td>
                    <td>@hit.Document?.Url</td>
                    <td>@hit.NoOfHits</td>
                    <td>@hit.Document?.IdxTime</td>
                    <td>@(hit.Missing.Count == 0 ? "[]" : $"[{string.Join(", ", hit.Missing)}]")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string Query { get; set; } = string.Empty;
    private string Database { get; set; } = "postgres";
    private bool CaseSensitive { get; set; }
    private int MaxAmount { get; set; } = 10;
    private bool IsSearching { get; set; }
    private bool IsClearingCache { get; set; }
    private string? ErrorMessage { get; set; }
    private string? CacheMessage { get; set; }
    private Shared.Model.SearchResult? SearchResult { get; set; }
    private string? Backend { get; set; }
    private string? Strategy { get; set; }
    private string? SearchApiInstance { get; set; }
    private string? CacheStatus { get; set; }

    private async Task ClearCacheAsync()
    {
        ErrorMessage = null;
        CacheMessage = null;
        IsClearingCache = true;

        try
        {
            var response = await ApiClient.ClearCacheAsync();
            CacheMessage = $"Cache ryddet. Næste søgning bør blive cache miss; gentag samme søgning for cache hit. Generation: {response.Generation}";
            CacheStatus = null;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Kunne ikke rydde cache: {ex.Message}";
        }
        finally
        {
            IsClearingCache = false;
        }
    }

    private async Task PerformSearchAsync()
    {
        ErrorMessage = null;
        CacheMessage = null;
        SearchResult = null;
        Backend = null;
        Strategy = null;
        SearchApiInstance = null;
        CacheStatus = null;

        if (string.IsNullOrWhiteSpace(Query))
        {
            ErrorMessage = "Angiv mindst ét søgeord.";
            return;
        }

        IsSearching = true;

        try
        {
            var request = new Shared.Model.SearchRequest
            {
                Query = Query,
                Database = Database,
                CaseSensitive = CaseSensitive,
                MaxAmount = MaxAmount
            };

            var apiResponse = await ApiClient.SearchAsync(request);
            SearchResult = apiResponse.Result;
            Backend = apiResponse.Backend;
            Strategy = apiResponse.Strategy;
            SearchApiInstance = apiResponse.SearchApiInstance;
            CacheStatus = apiResponse.CacheStatus;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Søgning fejlede: {ex.Message}";
        }
        finally
        {
            IsSearching = false;
        }
    }
}
