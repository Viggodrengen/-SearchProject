        </mxCell>
        <mxCell id="e0" edge="1" parent="1" source="browser" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="web" value="HTTP">
          <mxGeometry relative="1" as="geometry" />
