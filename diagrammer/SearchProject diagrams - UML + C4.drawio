        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" value="Kubernetes - Produktionsarkitektur" vertex="1">
          <mxGeometry height="40" width="760" x="40" y="25" as="geometry" />
        </mxCell>
        <mxCell id="sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" value="Målbillede for produktion: sådan kan containerne fra C4-diagrammet deployes som Kubernetes workloads." vertex="1">
          <mxGeometry height="30" width="1000" x="40" y="65" as="geometry" />
        </mxCell>
        <mxCell id="user" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=8" value="&lt;b&gt;Brugerens browser&lt;/b&gt;&lt;br&gt;[Ekstern klient]" vertex="1">
          <mxGeometry height="75" width="170" x="55" y="260" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" value="Kubernetes-diagrammet viser ønsket produktionsdrift med Kubernetes-sprog: Namespace, Ingress, Service, Deployment/Pod, StatefulSet, PVC, Secret/Vault og observability. Control Plane er ikke tegnet med, fordi den er implicit i platformen.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Trafikflow:&lt;/b&gt; Browseren rammer Ingress, som sender trafik videre til Services. Services giver stabile endpoints foran pods, så pods kan udskiftes eller skaleres uden at klienterne skal kende dem.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;X-akse:&lt;/b&gt; SearchApi ligger i sin egen skalerbare gruppe og kan køre som flere pods via HorizontalPodAutoscaler. Det svarer til at klone samme API bag et stabilt Service-endpoint.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Data og drift:&lt;/b&gt; PostgreSQL er stateful og kræver PersistentVolumeClaim. Redis bruges til cache. Loki/Grafana bruges til logs og dashboards, mens Prometheus kan scrape metrics til performance-overblik. Secrets/Vault forbindes til workloads som secrets/env. Z-akse forklares som en mulig database-retning: partitionering/sharding eller managed database udenfor clusteret." vertex="1">
          <mxGeometry height="213" width="1169" x="278" y="848" as="geometry" />
        </mxCell>
        <mxCell id="e0" edge="1" parent="1" source="user" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="ingress" value="HTTPS">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      <mxCell id="kubeDiagNote" value="KubeDiagrams kan bruges som generator, hvis vi senere laver rigtige Kubernetes YAML-manifests: kube-diagrams -f drawio -o diagram.drawio manifests.yaml. Her er diagrammet dog manuelt tilpasset til eksamen, så relationer og skaleringspointer er tydelige." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#EAF2FF;strokeColor=#6C8EBF;align=left;spacingLeft=8;fontSize=11" vertex="1" parent="1"><mxGeometry x="1175" y="835" width="260" height="100" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="8 - C4 Container syntax eksperiment" id="c4-syntax-experiment">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
<mxCell id="t" value="C4 Containerdiagram - syntaks-eksperiment" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="700" height="40" as="geometry"/></mxCell><mxCell id="sub" value="Samme arkitektur, men tegnet tættere på C4-eksemplet: person, system boundary, container-former, database-cylinder og dashed relationer." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="1000" height="30" as="geometry"/></mxCell><mxCell id="personHead" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0B6B00;strokeWidth=4;" vertex="1" parent="1"><mxGeometry x="150" y="125" width="90" height="90" as="geometry"/></mxCell><mxCell id="personBody" value="&lt;b&gt;Bruger&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Søger via browser eller CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0B6B00;strokeWidth=4;fontColor=#0B6B00;fontSize=13;arcSize=20;" vertex="1" parent="1"><mxGeometry x="100" y="200" width="190" height="115" as="geometry"/></mxCell><mxCell id="boundary" value="SearchProject&lt;br&gt;[Software System]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=16;fontStyle=1;align=left;verticalAlign=bottom;spacingLeft=12;spacingBottom=8;arcSize=4;" vertex="1" parent="1"><mxGeometry x="55" y="370" width="1320" height="500" as="geometry"/></mxCell><mxCell id="web" value="&lt;b&gt;SearchWebApp&lt;/b&gt;&lt;br&gt;[Container: Blazor Server]&lt;br&gt;&lt;br&gt;Web UI til søgning&lt;br&gt;✅ Implementeret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="160" y="440" width="230" height="120" as="geometry"/></mxCell><mxCell id="console" value="&lt;b&gt;ConsoleSearch&lt;/b&gt;&lt;br&gt;[Container: .NET CLI]&lt;br&gt;&lt;br&gt;Test/demo-klient&lt;br&gt;✅ Implementeret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="160" y="635" width="230" height="120" as="geometry"/></mxCell><mxCell id="lb" value="&lt;b&gt;Nginx&lt;/b&gt;&lt;br&gt;[Reverse proxy]&lt;br&gt;&lt;br&gt;Routing mellem API-replikaer&lt;br&gt;✅ Implementeret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="480" y="535" width="250" height="130" as="geometry"/></mxCell><mxCell id="api" value="&lt;b&gt;SearchApi&lt;/b&gt;&lt;br&gt;[Container: ASP.NET Core]&lt;br&gt;&lt;br&gt;Stateless søge-API&lt;br&gt;✅ X-skalerbar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="835" y="535" width="250" height="130" as="geometry"/></mxCell><mxCell id="redis" value="&lt;b&gt;Redis cache&lt;/b&gt;&lt;br&gt;[Container: Redis]&lt;br&gt;&lt;br&gt;Query cache&lt;br&gt;🟨 Arkitekturretning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;dashed=1;" vertex="1" parent="1"><mxGeometry x="1120" y="430" width="210" height="105" as="geometry"/></mxCell><mxCell id="obs" value="&lt;b&gt;Loki / Grafana / Prometheus&lt;/b&gt;&lt;br&gt;[Container: Observability]&lt;br&gt;&lt;br&gt;Logs, dashboards og metrics&lt;br&gt;📈 Drift" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;dashed=1;" vertex="1" parent="1"><mxGeometry x="1120" y="620" width="210" height="120" as="geometry"/></mxCell><mxCell id="idx" value="&lt;b&gt;Indexer&lt;/b&gt;&lt;br&gt;[Container: .NET job]&lt;br&gt;&lt;br&gt;Opbygger reverse index&lt;br&gt;🟨 Arkitekturretning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;arcSize=8;spacing=8;dashed=1;" vertex="1" parent="1"><mxGeometry x="480" y="735" width="230" height="110" as="geometry"/></mxCell><mxCell id="db" value="&lt;b&gt;PostgreSQL searchdb&lt;/b&gt;&lt;br&gt;[Container: Relational Database Schema]&lt;br&gt;&lt;br&gt;Dokumenter, ord og reverse index&lt;br&gt;✅ Implementeret i dev" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFFFFF;strokeColor=#1168BD;strokeWidth=3;fontColor=#1168BD;fontSize=13;spacing=8;" vertex="1" parent="1"><mxGeometry x="835" y="725" width="250" height="125" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;Læsning af diagrammet&lt;/b&gt;&lt;br&gt;C4-container-sproget bruger former/farver til typen af element: grøn person, blå interne containere/database og dashed relationer med korte labels.&lt;br&gt;&lt;br&gt;Status er lagt som tekst i boksene, så C4-syntaksen ikke blandes sammen med implementeringsstatus.&lt;br&gt;&lt;br&gt;Y-akse = funktionel opdeling i flere containere. X-akse = SearchApi kan klones. Z-akse = mulig database-sharding senere." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1120" y="135" width="300" height="190" as="geometry"/></mxCell><mxCell id="e1" value="Bruger UI" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="personBody" target="web"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="Bruger CLI" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="personBody" target="console"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="POST /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="web" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="POST /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="console" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="failover" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="lb" target="api"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="cache get/set" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="api" target="redis"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" value="læser index" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="api" target="db"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e8" value="skriver index" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="idx" target="db"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e9" value="logs/metrics" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#333333;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="api" target="obs"><mxGeometry relative="1" as="geometry"/></mxCell>      </root>
