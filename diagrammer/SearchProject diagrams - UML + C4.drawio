        <mxCell id="obs" value="Observability namespace" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#F3E8F8;strokeColor=#9673A6;fontStyle=1;startSize=30;arcSize=8" vertex="1" parent="cluster"><mxGeometry x="70" y="535" width="230" height="145" as="geometry"/></mxCell>
        <mxCell id="loki" value="&lt;b&gt;Loki&lt;/b&gt;&lt;br&gt;logs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;arcSize=8" vertex="1" parent="obs"><mxGeometry x="25" y="55" width="80" height="55" as="geometry"/></mxCell>
        <mxCell id="grafana" value="&lt;b&gt;Grafana&lt;/b&gt;&lt;br&gt;dashboards" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;arcSize=8" vertex="1" parent="obs"><mxGeometry x="125" y="55" width="85" height="55" as="geometry"/></mxCell>

        <mxCell id="note" value="Diagrammet viser produktionsretningen for SearchProject i Kubernetes. Control Plane styrer ønsket tilstand: API Server modtager manifests, Scheduler placerer pods på worker nodes, Controller Manager holder antallet af pods stabilt, og etcd gemmer cluster state.&lt;br/&gt;&lt;br/&gt;Trafik kommer ind via en Ingress Controller og sendes videre til Kubernetes Services. Services giver stabile endpoints foran pods, som kan udskiftes eller skaleres. SearchApi vises med flere pods, hvilket svarer til x-akse skalering i produktion.&lt;br/&gt;&lt;br/&gt;PostgreSQL er vist som stateful workload med PersistentVolumeClaim, fordi databasen skal have persistent storage. Redis kan køre som cache-workload. Secrets/Vault bruges til credentials og connection strings, så de ikke ligger hårdkodet i applikationerne." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" vertex="1" parent="1"><mxGeometry x="40" y="835" width="1100" height="95" as="geometry"/></mxCell>

        <mxCell id="e0" value="HTTPS" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="user" target="ingress"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1" value="routes" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="cluster" source="ingress" target="svcWeb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="selects pod" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="node1" source="svcWeb" target="podWeb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="HTTP" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="node1" source="podWeb" target="svcLb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="selects pod" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="node1" source="svcLb" target="podLb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="HTTP" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="cluster" source="podLb" target="svcApi"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="load balances" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="node2" source="svcApi" target="podApi1"><mxGeometry relative="1" as="geometry"/></mxCell>
