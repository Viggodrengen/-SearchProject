        <mxCell id="ctxSub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" value="Overblik: viser SearchProject, brugeren og de eksterne systemer/platforme omkring løsningen." vertex="1">
          <mxGeometry height="30" width="850" x="40" y="65" as="geometry" />
        </mxCell>
        <mxCell id="person" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073763;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" value="&lt;b&gt;Politimedarbejder / Efterforsker&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Foretager autoriserede søgninger og ser søgeresultater" vertex="1">
