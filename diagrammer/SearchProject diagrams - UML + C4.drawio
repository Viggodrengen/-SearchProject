<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
  <diagram name="1 - UML Class" id="uml-class-page">
    <mxGraphModel dx="1200" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="UML - Class Diagram: datamodel og DTO-struktur" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" vertex="1" parent="1"><mxGeometry x="40" y="25" width="720" height="40" as="geometry"/></mxCell>
        <mxCell id="sub" value="Viser de centrale klasser, deres attributter og relationerne mellem søge-request, søgeresultat, hits og dokumenter." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" vertex="1" parent="1"><mxGeometry x="40" y="65" width="900" height="30" as="geometry"/></mxCell>
        <mxCell id="pkg" value="Shared.Model" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#F5F7FA;strokeColor=#2F3746;fontStyle=1;startSize=34;arcSize=6" vertex="1" parent="1"><mxGeometry x="70" y="125" width="760" height="430" as="geometry"/></mxCell>
        <mxCell id="req" value="&lt;b&gt;SearchRequest&lt;/b&gt;&lt;hr/&gt;+ Query: string&lt;br/&gt;+ MaxAmount: int&lt;br/&gt;+ CaseSensitive: bool&lt;br/&gt;+ Database: string" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="pkg"><mxGeometry x="35" y="70" width="240" height="120" as="geometry"/></mxCell>
        <mxCell id="res" value="&lt;b&gt;SearchResult&lt;/b&gt;&lt;hr/&gt;+ Query: string[]&lt;br/&gt;+ NoOfHits: int&lt;br/&gt;+ DocumentHits: List&amp;lt;DocumentHit&amp;gt;&lt;br/&gt;+ Ignored: List&amp;lt;string&amp;gt;&lt;br/&gt;+ TimeUsed: TimeSpan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="pkg"><mxGeometry x="330" y="70" width="280" height="145" as="geometry"/></mxCell>
        <mxCell id="hit" value="&lt;b&gt;DocumentHit&lt;/b&gt;&lt;hr/&gt;+ Document: BEDocument?&lt;br/&gt;+ NoOfHits: int&lt;br/&gt;+ Missing: List&amp;lt;string&amp;gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="pkg"><mxGeometry x="220" y="275" width="240" height="115" as="geometry"/></mxCell>
        <mxCell id="doc" value="&lt;b&gt;BEDocument&lt;/b&gt;&lt;hr/&gt;+ Id: int&lt;br/&gt;+ Url: string&lt;br/&gt;+ IdxTime: DateTime&lt;br/&gt;+ CreationTime: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="pkg"><mxGeometry x="505" y="272" width="230" height="120" as="geometry"/></mxCell>
        <mxCell id="e1" value="indeholder hits 0..*" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="pkg" source="res" target="hit"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="matcher dokument 0..1" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="pkg" source="hit" target="doc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note" value="Klassediagrammet viser de centrale dataobjekter i søgeflowet. SearchRequest er inputtet til en søgning og fungerer teknisk som en DTO, selvom den ikke hedder SearchRequestDTO. Projektet bruger domænenære navne, så klassen beskriver sin rolle: en søgeforespørgsel.&lt;br/&gt;&lt;br/&gt;SearchResult er outputtet fra søgningen. Det indeholder den behandlede query, samlet antal hits, ignorerede søgeord og tidsforbrug. Et SearchResult indeholder 0..* DocumentHit, fordi et søgeresultat kan bestå af flere dokumentmatches.&lt;br/&gt;&lt;br/&gt;DocumentHit beskriver ét dokuments match og peger på et BEDocument, som indeholder metadata som id, url og indekseringstidspunkt." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" vertex="1" parent="1"><mxGeometry x="70" y="590" width="820" height="180" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="2 - UML Object" id="uml-object-page">
    <mxGraphModel dx="1200" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="UML - Object Diagram: cached søgeresultat" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" vertex="1" parent="1"><mxGeometry x="40" y="25" width="700" height="40" as="geometry"/></mxCell>
        <mxCell id="sub" value="Viser et konkret runtime-snapshot, hvor en søgning er omsat til en cache key og et gemt SearchResult." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" vertex="1" parent="1"><mxGeometry x="40" y="65" width="900" height="30" as="geometry"/></mxCell>
        <mxCell id="req" value="&lt;b&gt;&lt;u&gt;request1 : SearchRequest&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Query = &amp;quot;Martin&amp;quot;&lt;br/&gt;MaxAmount = 10&lt;br/&gt;CaseSensitive = false&lt;br/&gt;Database = &amp;quot;postgresql&amp;quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="60" y="145" width="260" height="125" as="geometry"/></mxCell>
        <mxCell id="key" value="&lt;b&gt;&lt;u&gt;cacheKey1 : string&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;value = &amp;quot;q=Martin|max=10|case=false|db=postgresql&amp;quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="410" y="160" width="330" height="95" as="geometry"/></mxCell>
        <mxCell id="res" value="&lt;b&gt;&lt;u&gt;cachedResult1 : SearchResult&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Query = [&amp;quot;Martin&amp;quot;]&lt;br/&gt;NoOfHits = 2&lt;br/&gt;Ignored = []&lt;br/&gt;TimeUsed = 00:00:00.004" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="830" y="140" width="300" height="135" as="geometry"/></mxCell>
        <mxCell id="hit1" value="&lt;b&gt;&lt;u&gt;hit1 : DocumentHit&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;NoOfHits = 5&lt;br/&gt;Missing = []" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="700" y="350" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="hit2" value="&lt;b&gt;&lt;u&gt;hit2 : DocumentHit&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;NoOfHits = 2&lt;br/&gt;Missing = []" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="960" y="350" width="200" height="90" as="geometry"/></mxCell>
        <mxCell id="doc1" value="&lt;b&gt;&lt;u&gt;doc1 : BEDocument&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Id = 42&lt;br/&gt;Url = &amp;quot;/docs/case-martin.md&amp;quot;&lt;br/&gt;IdxTime = 2026-05-11 09:15" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="630" y="520" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="doc2" value="&lt;b&gt;&lt;u&gt;doc2 : BEDocument&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Id = 77&lt;br/&gt;Url = &amp;quot;/docs/search-api.md&amp;quot;&lt;br/&gt;IdxTime = 2026-05-11 09:17" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" vertex="1" parent="1"><mxGeometry x="955" y="520" width="300" height="110" as="geometry"/></mxCell>
        <mxCell id="e1" value="danner cache key" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="req" target="key"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="finder cached resultat" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="key" target="res"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="indeholder" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="res" target="hit1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="indeholder" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="res" target="hit2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="dokument" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="hit1" target="doc1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="dokument" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="hit2" target="doc2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note" value="Object diagrammet viser et konkret eksempel på systemets tilstand på et bestemt tidspunkt. En bruger har tidligere søgt på “Martin”, og søgningen er blevet omsat til en cache key. Til den cache key ligger der allerede et gemt SearchResult.&lt;br/&gt;&lt;br/&gt;Når samme søgning laves igen, behøver systemet ikke bygge resultatet forfra ved at søge i database eller indeksstruktur. I stedet kan systemet slå cache key’en op og returnere cachedResult1 direkte.&lt;br/&gt;&lt;br/&gt;Pointen er, at cachen ikke gemmer en ny type data. Den gemmer det samme søgeresultat, som systemet normalt ville returnere — bare midlertidigt, så gentagne søgninger kan besvares hurtigere." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" vertex="1" parent="1"><mxGeometry x="60" y="500" width="500" height="210" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="3 - UML Deployment" id="uml-deployment-page">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="UML - Deployment Diagram: Docker Compose dev miljø" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" vertex="1" parent="1"><mxGeometry x="40" y="25" width="760" height="40" as="geometry"/></mxCell>
        <mxCell id="sub" value="Viser hvordan applikationer og runtime-komponenter køres lokalt i udviklingsmiljøet." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="browser" value="&lt;&lt;device&gt;&gt;&lt;br/&gt;&lt;b&gt;User Browser&lt;/b&gt;&lt;br/&gt;Developer / tester" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;arcSize=10" vertex="1" parent="1"><mxGeometry x="55" y="265" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="env" value="&lt;&lt;execution environment&gt;&gt; Docker Compose dev miljø" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#F3EDFF;strokeColor=#7E57C2;fontStyle=1;startSize=38;arcSize=8" vertex="1" parent="1"><mxGeometry x="300" y="105" width="1040" height="610" as="geometry"/></mxCell>
        <mxCell id="app" value="Applikationslag" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#EEF7EE;strokeColor=#82B366;fontStyle=1;startSize=28;arcSize=8" vertex="1" parent="env"><mxGeometry x="35" y="70" width="640" height="280" as="geometry"/></mxCell>
        <mxCell id="data" value="Data og cache" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#FFF8E6;strokeColor=#D6B656;fontStyle=1;startSize=28;arcSize=8" vertex="1" parent="env"><mxGeometry x="715" y="70" width="285" height="280" as="geometry"/></mxCell>
        <mxCell id="obs" value="Observability" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#F3E8F8;strokeColor=#9673A6;fontStyle=1;startSize=28;arcSize=8" vertex="1" parent="env"><mxGeometry x="35" y="395" width="640" height="150" as="geometry"/></mxCell>
        <mxCell id="web" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;SearchWebApp&lt;/b&gt;&lt;br/&gt;Blazor Server&lt;hr/&gt;.NET applikation&lt;br/&gt;host: 5249" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;arcSize=8" vertex="1" parent="app"><mxGeometry x="25" y="80" width="180" height="120" as="geometry"/></mxCell>
        <mxCell id="lb" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;SearchLoadBalancer&lt;/b&gt;&lt;br/&gt;fordeler søgninger&lt;hr/&gt;.NET applikation&lt;br/&gt;host: 5075" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;arcSize=8" vertex="1" parent="app"><mxGeometry x="235" y="80" width="195" height="120" as="geometry"/></mxCell>
        <mxCell id="apis" value="SearchApi replikaer" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82B366;fontStyle=1;startSize=25;arcSize=8" vertex="1" parent="app"><mxGeometry x="460" y="35" width="160" height="220" as="geometry"/></mxCell>
        <mxCell id="api1" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;SearchApi A&lt;/b&gt;&lt;hr/&gt;.NET applikation&lt;br/&gt;host: 5017" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;arcSize=8" vertex="1" parent="apis"><mxGeometry x="20" y="45" width="120" height="75" as="geometry"/></mxCell>
        <mxCell id="api2" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;SearchApi B&lt;/b&gt;&lt;hr/&gt;.NET applikation&lt;br/&gt;host: 5018" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;arcSize=8" vertex="1" parent="apis"><mxGeometry x="20" y="135" width="120" height="75" as="geometry"/></mxCell>
        <mxCell id="pg" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br/&gt;persistent database&lt;hr/&gt;searchdb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;arcSize=8" vertex="1" parent="data"><mxGeometry x="45" y="60" width="200" height="105" as="geometry"/></mxCell>
        <mxCell id="redis" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;Redis&lt;/b&gt;&lt;br/&gt;query cache&lt;hr/&gt;midlertidige søgeresultater" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;arcSize=8" vertex="1" parent="data"><mxGeometry x="45" y="190" width="200" height="85" as="geometry"/></mxCell>
        <mxCell id="graf" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;Grafana&lt;/b&gt;&lt;br/&gt;dashboards / UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;arcSize=8" vertex="1" parent="obs"><mxGeometry x="55" y="50" width="175" height="75" as="geometry"/></mxCell>
        <mxCell id="loki" value="&lt;&lt;container&gt;&gt;&lt;br/&gt;&lt;b&gt;Loki&lt;/b&gt;&lt;br/&gt;log storage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;align=center;arcSize=8" vertex="1" parent="obs"><mxGeometry x="310" y="50" width="175" height="75" as="geometry"/></mxCell>
        <mxCell id="e0" value="HTTP" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="1" source="browser" target="web"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1" value="HTTP /api/search" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="app" source="web" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="HTTP" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="app" source="lb" target="api1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="HTTP" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="app" source="lb" target="api2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="SQL" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="env" source="api1" target="pg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="cache get/set" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="env" source="api2" target="redis"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="logs" style="endArrow=open;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#9673A6;labelBackgroundColor=#FFFFFF" edge="1" parent="env" source="apis" target="loki"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="læser logs" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#9673A6;labelBackgroundColor=#FFFFFF" edge="1" parent="obs" source="graf" target="loki"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note" value="Deployment-diagrammet viser udviklingsmiljøet, som køres med Docker Compose. Browseren ligger udenfor miljøet, fordi den ikke startes af Docker Compose.&lt;br/&gt;&lt;br/&gt;SearchWebApp kalder SearchLoadBalancer, og load balanceren fordeler søgninger til SearchApi A/B. Det viser x-akse skalering: samme API kan køre i flere instanser.&lt;br/&gt;&lt;br/&gt;PostgreSQL er persistent database, Redis bruges som cache, og Loki/Grafana bruges til logs og driftsoverblik. For læsbarhed vises kun repræsentative SQL/cache-forbindelser." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" vertex="1" parent="1"><mxGeometry x="40" y="735" width="1000" height="120" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="4 - C4 Context" id="c4-context-clean">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="ctxTitle" value="C4 - System Context Diagram" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="500" height="40" as="geometry"/></mxCell>
        <mxCell id="ctxSub" value="Zoomet ud: viser SearchProject, brugeren og de eksterne systemer/platforme omkring løsningen." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="person" value="&lt;b&gt;Politimedarbejder / Efterforsker&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Foretager autoriserede søgninger og ser søgeresultater" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073763;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="70" y="280" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="system" value="&lt;b&gt;SearchProject&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;Søgemaskine til opslag i indekserede dokumenter med fokus på drift, skalering, caching og observability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=13;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="465" y="250" width="290" height="180" as="geometry"/></mxCell>
        <mxCell id="broker" value="&lt;b&gt;Privat MitID Broker&lt;/b&gt;&lt;br&gt;[External Software System]&lt;br&gt;&lt;br&gt;Formidler autentificering mellem SearchProject og MitID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="205" width="230" height="120" as="geometry"/></mxCell>
        <mxCell id="mitid" value="&lt;b&gt;MitID&lt;/b&gt;&lt;br&gt;[External Software System]&lt;br&gt;&lt;br&gt;Autentificerer brugerens digitale identitet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="55" width="230" height="105" as="geometry"/></mxCell>
        <mxCell id="obs" value="&lt;b&gt;Observability platform&lt;/b&gt;&lt;br&gt;[External/Internal Platform]&lt;br&gt;&lt;br&gt;Modtager logs/metrics og bruges til driftsoverblik" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#657184;strokeColor=#4B5563;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="485" y="570" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="ctxNote" value="Context-diagrammet forklarer systemlandskabet uden interne detaljer. SearchProject vises som én samlet software system-boks. Redis, PostgreSQL, API-replikaer og interne komponenter vises først på container- og component-niveauerne." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1"><mxGeometry x="70" y="600" width="330" height="120" as="geometry"/></mxCell>
        <mxCell id="c1" value="bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="person" target="system"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c2" value="autentificerer bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="system" target="broker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c3" value="formidler login" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="broker" target="mitid"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c4" value="logs / metrics" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="system" target="obs"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="5 - C4 Container" id="c4-container-clean">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="conTitle" value="C4 - Container Diagram" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="450" height="40" as="geometry"/></mxCell>
        <mxCell id="conSub" value="Zoomer ind i SearchProject og viser applikationer, data stores og større runtime-komponenter." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="boundary" value="SearchProject [Software System]" style="swimlane;html=1;whiteSpace=wrap;startSize=34;container=1;collapsible=0;rounded=1;fillColor=#FFFFFF;strokeColor=#2F3746;fontColor=#313A4C;fontStyle=1;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1"><mxGeometry x="250" y="105" width="920" height="610" as="geometry"/></mxCell>
        <mxCell id="user2" value="&lt;b&gt;Bruger&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Søger i UI eller CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073763;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="55" y="250" width="155" height="115" as="geometry"/></mxCell>
        <mxCell id="web" value="&lt;b&gt;SearchWebApp&lt;/b&gt;&lt;br&gt;[Container: Blazor Server]&lt;br&gt;&lt;br&gt;Browserbaseret UI til søgninger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="60" y="70" width="185" height="105" as="geometry"/></mxCell>
        <mxCell id="console" value="&lt;b&gt;ConsoleSearch&lt;/b&gt;&lt;br&gt;[Container: .NET CLI]&lt;br&gt;&lt;br&gt;Console-klient til test/demo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="60" y="250" width="185" height="105" as="geometry"/></mxCell>
        <mxCell id="lb" value="&lt;b&gt;SearchLoadBalancer&lt;/b&gt;&lt;br&gt;[Container: ASP.NET Core]&lt;br&gt;&lt;br&gt;Round-robin og failover mellem API-replikaer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="330" y="160" width="200" height="120" as="geometry"/></mxCell>
        <mxCell id="api" value="&lt;b&gt;SearchApi&lt;/b&gt;&lt;br&gt;[Container: ASP.NET Core]&lt;br&gt;&lt;br&gt;Stateless søge-API, kan skaleres i flere replikaer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="615" y="160" width="205" height="120" as="geometry"/></mxCell>
        <mxCell id="indexer" value="&lt;b&gt;Indexer&lt;/b&gt;&lt;br&gt;[Container: .NET job]&lt;br&gt;&lt;br&gt;Indekserer dokumenter og skriver reverse index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="60" y="440" width="185" height="105" as="geometry"/></mxCell>
        <mxCell id="db" value="&lt;b&gt;Postgres searchdb&lt;/b&gt;&lt;br&gt;[Container: PostgreSQL]&lt;br&gt;&lt;br&gt;Dokumenter, ord og reverse index" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#2D8C7B;strokeColor=#1D5E53;fontColor=#FFFFFF;fontSize=11;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="340" y="430" width="190" height="115" as="geometry"/></mxCell>
        <mxCell id="cache" value="&lt;b&gt;Redis cache&lt;/b&gt;&lt;br&gt;[Container: Redis]&lt;br&gt;&lt;br&gt;Cache til gentagne/hot queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6C85F;strokeColor=#9B6500;fontColor=#1F2937;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="625" y="330" width="190" height="100" as="geometry"/></mxCell>
        <mxCell id="obsc" value="&lt;b&gt;Loki + Grafana&lt;/b&gt;&lt;br&gt;[Container: Observability]&lt;br&gt;&lt;br&gt;Logs, dashboards og driftsoverblik" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#657184;strokeColor=#4B5563;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="625" y="470" width="190" height="100" as="geometry"/></mxCell>
        <mxCell id="conNote" value="Container-diagrammet viser ansvarsfordelingen i systemet. WebApp og ConsoleSearch er klienter, LoadBalancer fordeler søgninger, SearchApi udfører søgelogikken, Indexer opbygger indeks, PostgreSQL gemmer data, Redis cacher søgeresultater, og Loki/Grafana bruges til driftsoverblik." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1"><mxGeometry x="55" y="575" width="175" height="160" as="geometry"/></mxCell>
        <mxCell id="e1" value="bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="user2" target="web"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="user2" target="console"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="POST /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="web" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="POST /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="console" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="router request" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="lb" target="api"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="cache get/set" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="api" target="cache"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="læser index" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="api" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="skriver index" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="indexer" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="logs" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="api" target="obsc"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="6 - C4 Component" id="c4-component-clean">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="compTitle" value="C4 - Component Diagram" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="450" height="40" as="geometry"/></mxCell>
        <mxCell id="compSub" value="Zoomer ind i SearchApi-containeren og viser de vigtigste interne komponenter i søgeflowet." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="client" value="&lt;b&gt;SearchWebApp / LoadBalancer&lt;/b&gt;&lt;br&gt;[Container]&lt;br&gt;&lt;br&gt;Sender søgeforespørgsler til SearchApi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="1"><mxGeometry x="60" y="250" width="200" height="115" as="geometry"/></mxCell>
        <mxCell id="apiBoundary" value="SearchApi [Container: ASP.NET Core]" style="swimlane;html=1;whiteSpace=wrap;startSize=34;container=1;collapsible=0;rounded=1;fillColor=#FFFFFF;strokeColor=#2F3746;fontColor=#313A4C;fontStyle=1;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1"><mxGeometry x="320" y="130" width="650" height="470" as="geometry"/></mxCell>
        <mxCell id="controller" value="&lt;b&gt;SearchController&lt;/b&gt;&lt;br&gt;[Component: ASP.NET Controller]&lt;br&gt;&lt;br&gt;Modtager HTTP requests og returnerer responses" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="220" y="60" width="230" height="105" as="geometry"/></mxCell>
        <mxCell id="service" value="&lt;b&gt;SearchService&lt;/b&gt;&lt;br&gt;[Component: Application service]&lt;br&gt;&lt;br&gt;Orkestrerer validering, cache, søgelogik og mapping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="205" y="200" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="validator" value="&lt;b&gt;RequestValidator&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Validerer og normaliserer input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="35" y="345" width="180" height="85" as="geometry"/></mxCell>
        <mxCell id="repo" value="&lt;b&gt;DBRepository&lt;/b&gt;&lt;br&gt;[Component: Data access]&lt;br&gt;&lt;br&gt;Læser dokumenter og reverse index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="250" y="345" width="185" height="85" as="geometry"/></mxCell>
        <mxCell id="mapper" value="&lt;b&gt;DTO / Mapper&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Mapper interne data til SearchResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="470" y="345" width="150" height="85" as="geometry"/></mxCell>
        <mxCell id="db2" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;[Container]&lt;br&gt;&lt;br&gt;Søgedata og index" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#2D8C7B;strokeColor=#1D5E53;fontColor=#FFFFFF;fontSize=11;spacing=6;" vertex="1" parent="1"><mxGeometry x="555" y="650" width="180" height="95" as="geometry"/></mxCell>
        <mxCell id="compNote" value="Component-diagrammet viser kun indersiden af SearchApi. Det forklarer, hvordan et søgekald går fra controlleren til en application service, videre gennem validering/dataadgang/mapping og ender som et SearchResult. Database og klient er vist udenfor containeren, fordi de ikke er interne komponenter i SearchApi." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="390" height="150" as="geometry"/></mxCell>
        <mxCell id="ce1" value="HTTP /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="client" target="controller"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce2" value="kalder" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="controller" target="service"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce3" value="validerer" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="service" target="validator"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce4" value="henter data" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="service" target="repo"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce5" value="mapper response" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="service" target="mapper"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce6" value="SQL" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="repo" target="db2"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="7 - Kubernetes Production" id="k8s-production-page">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="title" value="Kubernetes - Production Cluster Architecture" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" vertex="1" parent="1"><mxGeometry x="40" y="25" width="760" height="40" as="geometry"/></mxCell>
        <mxCell id="sub" value="Målbillede for production: SearchProject køres som Kubernetes workloads med Services, Ingress, persistent storage og observability." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" vertex="1" parent="1"><mxGeometry x="40" y="65" width="1000" height="30" as="geometry"/></mxCell>

        <mxCell id="user" value="&lt;b&gt;User Browser&lt;/b&gt;&lt;br&gt;[External client]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=8" vertex="1" parent="1"><mxGeometry x="55" y="245" width="170" height="75" as="geometry"/></mxCell>

        <mxCell id="cluster" value="Kubernetes Cluster - production" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#F3EDFF;strokeColor=#7E57C2;fontStyle=1;startSize=38;arcSize=8" vertex="1" parent="1"><mxGeometry x="270" y="105" width="1180" height="710" as="geometry"/></mxCell>

        <mxCell id="control" value="Control Plane" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#EEF2F7;strokeColor=#657184;fontStyle=1;startSize=30;arcSize=8" vertex="1" parent="cluster"><mxGeometry x="35" y="60" width="1080" height="120" as="geometry"/></mxCell>
        <mxCell id="apiServer" value="&lt;b&gt;API Server&lt;/b&gt;&lt;br&gt;modtager desired state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#657184;fontSize=11;arcSize=8" vertex="1" parent="control"><mxGeometry x="45" y="45" width="170" height="55" as="geometry"/></mxCell>
        <mxCell id="scheduler" value="&lt;b&gt;Scheduler&lt;/b&gt;&lt;br&gt;placerer pods" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#657184;fontSize=11;arcSize=8" vertex="1" parent="control"><mxGeometry x="255" y="45" width="165" height="55" as="geometry"/></mxCell>
        <mxCell id="controller" value="&lt;b&gt;Controller Manager&lt;/b&gt;&lt;br&gt;holder ønsket tilstand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#657184;fontSize=11;arcSize=8" vertex="1" parent="control"><mxGeometry x="465" y="45" width="190" height="55" as="geometry"/></mxCell>
        <mxCell id="etcd" value="&lt;b&gt;etcd&lt;/b&gt;&lt;br&gt;cluster state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#657184;fontSize=11;arcSize=8" vertex="1" parent="control"><mxGeometry x="700" y="45" width="150" height="55" as="geometry"/></mxCell>
        <mxCell id="secrets" value="&lt;b&gt;Secrets / Vault&lt;/b&gt;&lt;br&gt;connection strings og credentials" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;arcSize=8" vertex="1" parent="control"><mxGeometry x="885" y="40" width="170" height="65" as="geometry"/></mxCell>

        <mxCell id="ingress" value="&lt;b&gt;Ingress Controller&lt;/b&gt;&lt;br&gt;[LoadBalancer / HTTPS entrypoint]&lt;br&gt;router trafik ind i clusteret" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=12;arcSize=8" vertex="1" parent="cluster"><mxGeometry x="70" y="235" width="230" height="95" as="geometry"/></mxCell>

        <mxCell id="node1" value="Worker Node A" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#EEF7EE;strokeColor=#82B366;fontStyle=1;startSize=30;arcSize=8" vertex="1" parent="cluster"><mxGeometry x="350" y="220" width="330" height="280" as="geometry"/></mxCell>
        <mxCell id="svcWeb" value="&lt;b&gt;Service&lt;/b&gt;&lt;br&gt;search-webapp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;arcSize=8" vertex="1" parent="node1"><mxGeometry x="30" y="50" width="120" height="55" as="geometry"/></mxCell>
        <mxCell id="podWeb" value="&lt;b&gt;Pod&lt;/b&gt;&lt;br&gt;SearchWebApp&lt;br&gt;Blazor Server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;arcSize=8" vertex="1" parent="node1"><mxGeometry x="180" y="45" width="125" height="70" as="geometry"/></mxCell>
        <mxCell id="svcLb" value="&lt;b&gt;Service&lt;/b&gt;&lt;br&gt;search-lb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;arcSize=8" vertex="1" parent="node1"><mxGeometry x="30" y="155" width="120" height="55" as="geometry"/></mxCell>
        <mxCell id="podLb" value="&lt;b&gt;Pod&lt;/b&gt;&lt;br&gt;SearchLoadBalancer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;arcSize=8" vertex="1" parent="node1"><mxGeometry x="180" y="150" width="125" height="65" as="geometry"/></mxCell>

        <mxCell id="node2" value="Worker Node B" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#EEF7EE;strokeColor=#82B366;fontStyle=1;startSize=30;arcSize=8" vertex="1" parent="cluster"><mxGeometry x="730" y="220" width="330" height="280" as="geometry"/></mxCell>
        <mxCell id="svcApi" value="&lt;b&gt;Service&lt;/b&gt;&lt;br&gt;search-api&lt;br&gt;stable endpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;arcSize=8" vertex="1" parent="node2"><mxGeometry x="30" y="95" width="120" height="70" as="geometry"/></mxCell>
        <mxCell id="podApi1" value="&lt;b&gt;Pod&lt;/b&gt;&lt;br&gt;SearchApi A" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;arcSize=8" vertex="1" parent="node2"><mxGeometry x="185" y="55" width="120" height="60" as="geometry"/></mxCell>
        <mxCell id="podApi2" value="&lt;b&gt;Pod&lt;/b&gt;&lt;br&gt;SearchApi B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;arcSize=8" vertex="1" parent="node2"><mxGeometry x="185" y="145" width="120" height="60" as="geometry"/></mxCell>

        <mxCell id="stateful" value="Stateful/data layer" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#FFF8E6;strokeColor=#D6B656;fontStyle=1;startSize=30;arcSize=8" vertex="1" parent="cluster"><mxGeometry x="350" y="535" width="710" height="145" as="geometry"/></mxCell>
        <mxCell id="pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;StatefulSet&lt;br&gt;searchdb" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;arcSize=8" vertex="1" parent="stateful"><mxGeometry x="45" y="55" width="150" height="75" as="geometry"/></mxCell>
        <mxCell id="pv" value="&lt;b&gt;PersistentVolumeClaim&lt;/b&gt;&lt;br&gt;database storage" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11" vertex="1" parent="stateful"><mxGeometry x="240" y="55" width="160" height="75" as="geometry"/></mxCell>
