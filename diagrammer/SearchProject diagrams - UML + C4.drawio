        <mxCell id="e8" value="SQL" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="cluster" source="podApi1" target="pg"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="cache get/set" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="cluster" source="podApi2" target="redis"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="mounts" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" edge="1" parent="stateful" source="pg" target="pv"><mxGeometry relative="1" as="geometry"/></mxCell>
