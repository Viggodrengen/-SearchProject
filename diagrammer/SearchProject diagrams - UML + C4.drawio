  <diagram name="1 - UML Class" id="6Fojqi37mAonKl2tS3hs">
    <mxGraphModel dx="917" dy="673" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" value="UML - Class Diagram: datamodel og DTO-struktur" vertex="1">
          <mxGeometry height="40" width="720" x="40" y="25" as="geometry" />
        </mxCell>
        <mxCell id="sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" value="Viser de centrale klasser, deres attributter og relationerne mellem søge-request, søgeresultat, hits og dokumenter." vertex="1">
          <mxGeometry height="30" width="900" x="40" y="65" as="geometry" />
        </mxCell>
        <mxCell id="pkg" parent="1" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#F5F7FA;strokeColor=#2F3746;fontStyle=1;startSize=34;arcSize=6" value="Shared.Model" vertex="1">
          <mxGeometry height="430" width="760" x="70" y="125" as="geometry" />
        </mxCell>
        <mxCell id="req" parent="pkg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;SearchRequest&lt;/b&gt;&lt;hr/&gt;+ Query: string&lt;br/&gt;+ MaxAmount: int&lt;br/&gt;+ CaseSensitive: bool&lt;br/&gt;+ Database: string" vertex="1">
          <mxGeometry height="120" width="240" x="35" y="70" as="geometry" />
        </mxCell>
        <mxCell id="res" parent="pkg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;SearchResult&lt;/b&gt;&lt;hr/&gt;+ Query: string[]&lt;br/&gt;+ NoOfHits: int&lt;br/&gt;+ DocumentHits: List&amp;lt;DocumentHit&amp;gt;&lt;br/&gt;+ Ignored: List&amp;lt;string&amp;gt;&lt;br/&gt;+ TimeUsed: TimeSpan" vertex="1">
          <mxGeometry height="145" width="280" x="330" y="70" as="geometry" />
        </mxCell>
        <mxCell id="hit" parent="pkg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;DocumentHit&lt;/b&gt;&lt;hr/&gt;+ Document: BEDocument?&lt;br/&gt;+ NoOfHits: int&lt;br/&gt;+ Missing: List&amp;lt;string&amp;gt;" vertex="1">
          <mxGeometry height="115" width="240" x="220" y="275" as="geometry" />
        </mxCell>
        <mxCell id="doc" parent="pkg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;BEDocument&lt;/b&gt;&lt;hr/&gt;+ Id: int&lt;br/&gt;+ Url: string&lt;br/&gt;+ IdxTime: DateTime&lt;br/&gt;+ CreationTime: DateTime" vertex="1">
          <mxGeometry height="120" width="230" x="505" y="272" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="pkg" source="res" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="hit" value="indeholder hits 0..*">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="pkg" source="hit" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="doc" value="matcher dokument 0..1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" value="Klassediagrammet viser de centrale dataobjekter i søgeflowet. SearchRequest er inputtet til en søgning og fungerer teknisk som en DTO, selvom den ikke hedder SearchRequestDTO. Projektet bruger domænenære navne, så klassen beskriver sin rolle: en søgeforespørgsel.&lt;br/&gt;&lt;br/&gt;SearchResult er outputtet fra søgningen. Det indeholder den behandlede query, samlet antal hits, ignorerede søgeord og tidsforbrug. Et SearchResult indeholder 0..* DocumentHit, fordi et søgeresultat kan bestå af flere dokumentmatches.&lt;br/&gt;&lt;br/&gt;DocumentHit beskriver ét dokuments match og peger på et BEDocument, som indeholder metadata som id, url og indekseringstidspunkt." vertex="1">
          <mxGeometry height="180" width="820" x="70" y="590" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2 - UML Object" id="1rwhvNK0u67MxXGgCbVk">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033" value="UML - Object Diagram: cachet søgeresultat" vertex="1">
          <mxGeometry height="40" width="700" x="40" y="25" as="geometry" />
        </mxCell>
        <mxCell id="sub" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678" value="Viser et konkret runtime-snapshot, hvor en søgning er omsat til en cache-nøgle og et gemt SearchResult." vertex="1">
          <mxGeometry height="30" width="900" x="40" y="65" as="geometry" />
        </mxCell>
        <mxCell id="req" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;request1 : SearchRequest&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Query = &amp;quot;Martin&amp;quot;&lt;br/&gt;MaxAmount = 10&lt;br/&gt;CaseSensitive = false&lt;br/&gt;Database = &amp;quot;postgresql&amp;quot;" vertex="1">
          <mxGeometry height="125" width="260" x="60" y="145" as="geometry" />
        </mxCell>
        <mxCell id="key" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;cacheKey1 : string&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;value = &amp;quot;q=Martin|max=10|case=false|db=postgresql&amp;quot;" vertex="1">
          <mxGeometry height="95" width="330" x="410" y="160" as="geometry" />
        </mxCell>
        <mxCell id="res" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;cachedResult1 : SearchResult&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Query = [&amp;quot;Martin&amp;quot;]&lt;br/&gt;NoOfHits = 2&lt;br/&gt;Ignored = []&lt;br/&gt;TimeUsed = 00:00:00.004" vertex="1">
          <mxGeometry height="135" width="300" x="830" y="140" as="geometry" />
        </mxCell>
        <mxCell id="hit1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;hit1 : DocumentHit&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;NoOfHits = 5&lt;br/&gt;Missing = []" vertex="1">
          <mxGeometry height="90" width="220" x="700" y="350" as="geometry" />
        </mxCell>
        <mxCell id="hit2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;hit2 : DocumentHit&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;NoOfHits = 2&lt;br/&gt;Missing = []" vertex="1">
          <mxGeometry height="90" width="200" x="960" y="350" as="geometry" />
        </mxCell>
        <mxCell id="doc1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;doc1 : BEDocument&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Id = 42&lt;br/&gt;Url = &amp;quot;/docs/case-martin.md&amp;quot;&lt;br/&gt;IdxTime = 2026-05-11 09:15" vertex="1">
          <mxGeometry height="110" width="300" x="630" y="520" as="geometry" />
        </mxCell>
        <mxCell id="doc2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;spacingLeft=8;arcSize=6" value="&lt;b&gt;&lt;u&gt;doc2 : BEDocument&lt;/u&gt;&lt;/b&gt;&lt;hr/&gt;Id = 77&lt;br/&gt;Url = &amp;quot;/docs/search-api.md&amp;quot;&lt;br/&gt;IdxTime = 2026-05-11 09:17" vertex="1">
          <mxGeometry height="110" width="300" x="955" y="520" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="req" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="key" value="danner cache-nøgle">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="key" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="res" value="finder cachet resultat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="res" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="hit1" value="indeholder">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="res" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="hit2" value="indeholder">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="hit1" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="doc1" value="dokument">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" parent="1" source="hit2" style="endArrow=open;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;labelBackgroundColor=#FFFFFF" target="doc2" value="dokument">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13" value="Object diagrammet viser et konkret eksempel på systemets tilstand på et bestemt tidspunkt. En bruger har tidligere søgt på “Martin”, og søgningen er blevet omsat til en cache-nøgle. Til den cache-nøgle ligger der allerede et gemt SearchResult.&lt;br/&gt;&lt;br/&gt;Når samme søgning laves igen, behøver systemet ikke bygge resultatet forfra ved at søge i database eller indeksstruktur. I stedet kan systemet slå cache-nøgle’en op og returnere cachedResult1 direkte.&lt;br/&gt;&lt;br/&gt;Pointen er, at cachen ikke gemmer en ny type data. Den gemmer det samme søgeresultat, som systemet normalt ville returnere — bare midlertidigt, så gentagne søgninger kan besvares hurtigere." vertex="1">
          <mxGeometry height="210" width="500" x="60" y="500" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
