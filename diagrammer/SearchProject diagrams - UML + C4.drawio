        </mxCell>
        <mxCell id="e9" edge="1" parent="boundary" source="api" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" target="obsc" value="logs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="user2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073763;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" value="&lt;b&gt;Bruger&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Søger i UI eller CLI" vertex="1">
          <mxGeometry height="115" width="155" x="43" y="290" as="geometry" />
        </mxCell>
        <mxCell id="conNote" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" value="Containerdiagrammet er hoveddiagrammet til eksamen. Det viser målarkitekturen og markerer samtidig, hvad der er implementeret i walking skeleton’et, og hvad der er arkitekturretning.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Y-akse:&lt;/b&gt; Systemet er delt funktionelt op i WebApp, ConsoleSearch, Nginx, SearchApi, database, cache og observability. Det gør ansvaret tydeligere og gør det nemmere at ændre eller skalere enkelte dele.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;X-akse:&lt;/b&gt; SearchApi er stateless og kan klones i flere replikaer bag Nginx i Docker Compose eller Service/Ingress i Kubernetes. Det er relevant, fordi søge-API’et er den del, der forventes at få mest trafik.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Z-akse:&lt;/b&gt; Databasen kan på sigt segmenteres/shardes, fx efter tenant, brugergruppe eller datadomæne. Det er ikke implementeret i walking skeleton’et, men er den database-retning vi kan pege på i produktionsarkitekturen.&lt;br/&gt;&lt;br/&gt;Redis viser caching-princippet for gentagne søgninger. Loki/Grafana viser logs og driftsoverblik, mens Prometheus hører til metrics/performance-retningen i produktion." vertex="1">
          <mxGeometry height="200" width="780" x="360" y="740" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="user2" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" target="web" value="bruger">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="user2" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" target="console" value="bruger">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="P1Hb76Tmcx7bXNGQMDiH-1" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=light-dark(#07427b, #ededed);gradientColor=none;strokeColor=none;" value="" vertex="1">
          <mxGeometry height="80" width="80" x="80.5" y="232" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
