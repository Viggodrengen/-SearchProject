@startuml
!pragma layout smetana
skinparam linetype ortho

actor User as user

node "Kubernetes cluster\nMinikube / managed target" as k8s {
  frame "Namespace: searchproject" as nsapp {
    node "Ingress\nsearch.example.local\nTLS" as ing #D8EAFE

    node "Service webapp-svc\nClusterIP" as svcweb #D8EAFE
    node "Deployment searchwebapp\nreplicas: 2" as depweb #D8EAFE

    node "Service searchlb-svc\nClusterIP" as svclb #D8EAFE
    node "Deployment searchloadbalancer\nreplicas: 2" as deplb #D8EAFE

    node "Service searchapi-svc\nClusterIP" as svcapi #D8EAFE
    node "Deployment searchapi\nreplicas: 3" as depapi #D8EAFE

    database "StatefulSet redis-cache <<planned>>\nPVC: redis-data" as ssredis #FFF3C4
    database "StatefulSet postgres-shard-a\nprimary+replica\nPVC: pg-a-data" as sspga #A7F3D0
    database "StatefulSet postgres-shard-b <<planned>>\nprimary+replica\nPVC: pg-b-data" as sspgb #FFF3C4

    artifact "ConfigMap + Secret\nconn strings, flags, ttl" as cfg #E2E8F0
    artifact "HPA searchapi <<planned>>\nCPU + RPS" as hpa #FFF3C4
  }

  frame "Namespace: observability" as nsobs {
    node "Prometheus <<planned>>" as prom #FFF3C4
    node "Grafana" as grafana #EDE9FE
    node "Loki" as loki #EDE9FE
    node "OTel Collector <<planned>>" as otel #FFF3C4
  }

  artifact "PVC pg-a-data" as pvga #DCFCE7
  artifact "PVC pg-b-data <<planned>>" as pvgb #FFF3C4
  artifact "PVC redis-data <<planned>>" as pvredis #FFF3C4
}

user --> ing : HTTPS
ing --> svcweb : route
svcweb --> depweb : target pods
depweb --> svclb : HTTP /api/search
svclb --> deplb : target pods
deplb --> svcapi : HTTP
svcapi --> depapi : target pods
depapi --> ssredis : TCP 6379
depapi --> sspga : SQL shard A
depapi --> sspgb : SQL shard B (planned)
cfg --> depapi : config + secrets
cfg --> deplb : config + secrets
hpa --> depapi : scale target
prom --> depapi : scrape /metrics (planned)
prom --> deplb : scrape /metrics (planned)
grafana --> prom : query metrics (planned)
grafana --> loki : query logs
depapi --> loki : logs
deplb --> loki : logs
depapi --> otel : optional export
sspga --> pvga : mount
sspgb --> pvgb : mount
ssredis --> pvredis : mount
@enduml
