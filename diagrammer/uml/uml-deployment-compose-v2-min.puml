@startuml
!pragma layout smetana
skinparam linetype ortho

actor User

node "Docker Host (compose)" {
  node "SearchWebApp" as Web
  node "SearchLoadBalancer" as LB
  node "SearchApi x2" as API
  database "Postgres" as PG
  node "Redis <<planned>>" as Redis
  node "Loki + Grafana" as Obs
}

User --> Web : browser
Web --> LB : /api/search
LB --> API : route request
API --> PG : SQL
API --> Redis : cache (planned)
API --> Obs : logs/metrics
LB --> Obs : logs
@enduml
