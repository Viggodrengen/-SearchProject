@startuml
!pragma layout smetana
skinparam linetype ortho

node "Client node" as client {
  artifact "Browser / Console client" as clientapp
}

node "Docker host\n(compose network: search-net)" as host {
  node "searchwebapp\nimage: SearchWebApp\n5249->8080" as web #D8EAFE
  node "searchloadbalancer\nimage: SearchLoadBalancer\n5075->8080" as lb #D8EAFE
  node "searchapi1\nimage: SearchApi\n5017->8080" as api1 #D8EAFE
  node "searchapi2\nimage: SearchApi\n5018->8080" as api2 #D8EAFE

  node "redis-cache <<planned>>\nimage: redis:7\nport: 6379" as redis #FFF3C4

  database "postgres-a\nprimary shard A\nport: 5432" as pga #A7F3D0
  database "postgres-b <<planned>>\nshard B\nport: 5433 internal" as pgb #FFF3C4

  node "loki\nport: 3100" as loki #EDE9FE
  node "grafana\nport: 3000" as grafana #EDE9FE
  node "prometheus <<planned>>\nport: 9090" as prom #FFF3C4
  node "otel-collector <<planned>>" as otel #FFF3C4

  artifact "volume: postgres-data-a" as vga #DCFCE7
  artifact "volume: postgres-data-b <<planned>>" as vgb #FFF3C4
  artifact "volume: grafana-data" as vgr #DDD6FE
}

clientapp --> web : HTTPS 5249
web --> lb : HTTP /api/search
lb --> api1 : HTTP 8080
lb --> api2 : HTTP 8080
api1 --> redis : TCP 6379 (cache)
api2 --> redis : TCP 6379 (cache)
api1 --> pga : SQL 5432
api2 --> pga : SQL 5432
api1 --> pgb : SQL shard B (planned)
api2 --> pgb : SQL shard B (planned)
api1 --> loki : logs
api2 --> loki : logs
lb --> loki : logs
grafana --> loki : query logs
grafana --> prom : query metrics (planned)
prom --> api1 : scrape /metrics (planned)
prom --> api2 : scrape /metrics (planned)
prom --> lb : scrape /metrics (planned)
api1 --> otel : optional export
api2 --> otel : optional export
pga --> vga : mount
pgb --> vgb : mount
grafana --> vgr : mount
@enduml
