<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" type="device">
  <diagram name="C4 Context" id="c4-context-clean">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="ctxTitle" value="C4 - System Context Diagram" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="500" height="40" as="geometry"/></mxCell>
        <mxCell id="ctxSub" value="Zoomet ud: viser SearchProject, brugeren og de eksterne systemer/platforme omkring løsningen." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="person" value="&lt;b&gt;Politimedarbejder / Efterforsker&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Foretager autoriserede søgninger og ser søgeresultater" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073763;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="70" y="280" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="system" value="&lt;b&gt;SearchProject&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;Søgemaskine til opslag i indekserede dokumenter med fokus på drift, skalering, caching og observability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=13;arcSize=8;spacing=10;" vertex="1" parent="1"><mxGeometry x="465" y="250" width="290" height="180" as="geometry"/></mxCell>
        <mxCell id="broker" value="&lt;b&gt;Privat MitID Broker&lt;/b&gt;&lt;br&gt;[External Software System]&lt;br&gt;&lt;br&gt;Formidler autentificering mellem SearchProject og MitID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="205" width="230" height="120" as="geometry"/></mxCell>
        <mxCell id="mitid" value="&lt;b&gt;MitID&lt;/b&gt;&lt;br&gt;[External Software System]&lt;br&gt;&lt;br&gt;Autentificerer brugerens digitale identitet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="920" y="55" width="230" height="105" as="geometry"/></mxCell>
        <mxCell id="obs" value="&lt;b&gt;Observability platform&lt;/b&gt;&lt;br&gt;[External/Internal Platform]&lt;br&gt;&lt;br&gt;Modtager logs/metrics og bruges til driftsoverblik" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#657184;strokeColor=#4B5563;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="485" y="570" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="ctxNote" value="Context-diagrammet forklarer systemlandskabet uden interne detaljer. SearchProject vises som én samlet software system-boks. Redis, PostgreSQL, API-replikaer og interne komponenter vises først på container- og component-niveauerne." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1"><mxGeometry x="70" y="600" width="330" height="120" as="geometry"/></mxCell>
        <mxCell id="c1" value="bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="person" target="system"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c2" value="autentificerer bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="system" target="broker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c3" value="formidler login" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="broker" target="mitid"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c4" value="logs / metrics" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="system" target="obs"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="C4 Container" id="c4-container-clean">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="conTitle" value="C4 - Container Diagram" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="450" height="40" as="geometry"/></mxCell>
        <mxCell id="conSub" value="Zoomer ind i SearchProject og viser applikationer, data stores og større runtime-komponenter." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="boundary" value="SearchProject [Software System]" style="swimlane;html=1;whiteSpace=wrap;startSize=34;container=1;collapsible=0;rounded=1;fillColor=#FFFFFF;strokeColor=#2F3746;fontColor=#313A4C;fontStyle=1;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1"><mxGeometry x="250" y="105" width="920" height="610" as="geometry"/></mxCell>
        <mxCell id="user2" value="&lt;b&gt;Bruger&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Søger i UI eller CLI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073763;fontColor=#FFFFFF;fontSize=12;arcSize=8;spacing=8;" vertex="1" parent="1"><mxGeometry x="55" y="250" width="155" height="115" as="geometry"/></mxCell>
        <mxCell id="web" value="&lt;b&gt;SearchWebApp&lt;/b&gt;&lt;br&gt;[Container: Blazor Server]&lt;br&gt;&lt;br&gt;Browserbaseret UI til søgninger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="60" y="70" width="185" height="105" as="geometry"/></mxCell>
        <mxCell id="console" value="&lt;b&gt;ConsoleSearch&lt;/b&gt;&lt;br&gt;[Container: .NET CLI]&lt;br&gt;&lt;br&gt;Console-klient til test/demo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="60" y="250" width="185" height="105" as="geometry"/></mxCell>
        <mxCell id="lb" value="&lt;b&gt;SearchLoadBalancer&lt;/b&gt;&lt;br&gt;[Container: ASP.NET Core]&lt;br&gt;&lt;br&gt;Round-robin og failover mellem API-replikaer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="330" y="160" width="200" height="120" as="geometry"/></mxCell>
        <mxCell id="api" value="&lt;b&gt;SearchApi&lt;/b&gt;&lt;br&gt;[Container: ASP.NET Core]&lt;br&gt;&lt;br&gt;Stateless søge-API, kan skaleres i flere replikaer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="615" y="160" width="205" height="120" as="geometry"/></mxCell>
        <mxCell id="indexer" value="&lt;b&gt;Indexer&lt;/b&gt;&lt;br&gt;[Container: .NET job]&lt;br&gt;&lt;br&gt;Indekserer dokumenter og skriver reverse index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="60" y="440" width="185" height="105" as="geometry"/></mxCell>
        <mxCell id="db" value="&lt;b&gt;Postgres searchdb&lt;/b&gt;&lt;br&gt;[Container: PostgreSQL]&lt;br&gt;&lt;br&gt;Dokumenter, ord og reverse index" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#2D8C7B;strokeColor=#1D5E53;fontColor=#FFFFFF;fontSize=11;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="340" y="430" width="190" height="115" as="geometry"/></mxCell>
        <mxCell id="cache" value="&lt;b&gt;Redis cache&lt;/b&gt;&lt;br&gt;[Container: Redis]&lt;br&gt;&lt;br&gt;Cache til gentagne/hot queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6C85F;strokeColor=#9B6500;fontColor=#1F2937;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="625" y="330" width="190" height="100" as="geometry"/></mxCell>
        <mxCell id="obsc" value="&lt;b&gt;Loki + Grafana&lt;/b&gt;&lt;br&gt;[Container: Observability]&lt;br&gt;&lt;br&gt;Logs, dashboards og driftsoverblik" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#657184;strokeColor=#4B5563;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="boundary"><mxGeometry x="625" y="470" width="190" height="100" as="geometry"/></mxCell>
        <mxCell id="conNote" value="Container-diagrammet viser ansvarsfordelingen i systemet. WebApp og ConsoleSearch er klienter, LoadBalancer fordeler søgninger, SearchApi udfører søgelogikken, Indexer opbygger indeks, PostgreSQL gemmer data, Redis cacher søgeresultater, og Loki/Grafana bruges til driftsoverblik." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1"><mxGeometry x="55" y="575" width="175" height="160" as="geometry"/></mxCell>
        <mxCell id="e1" value="bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="user2" target="web"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="bruger" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="user2" target="console"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="POST /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="web" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="POST /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="console" target="lb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="router request" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="lb" target="api"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="cache get/set" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="api" target="cache"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="læser index" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="api" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="skriver index" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="indexer" target="db"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="logs" style="endArrow=block;endFill=1;html=1;rounded=0;dashed=1;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="boundary" source="api" target="obsc"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="C4 Component" id="c4-component-clean">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="compTitle" value="C4 - Component Diagram" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;fontColor=#172033;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="450" height="40" as="geometry"/></mxCell>
        <mxCell id="compSub" value="Zoomer ind i SearchApi-containeren og viser de vigtigste interne komponenter i søgeflowet." style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#5d6678;" vertex="1" parent="1"><mxGeometry x="40" y="65" width="850" height="30" as="geometry"/></mxCell>
        <mxCell id="client" value="&lt;b&gt;SearchWebApp / LoadBalancer&lt;/b&gt;&lt;br&gt;[Container]&lt;br&gt;&lt;br&gt;Sender søgeforespørgsler til SearchApi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="1"><mxGeometry x="60" y="250" width="200" height="115" as="geometry"/></mxCell>
        <mxCell id="apiBoundary" value="SearchApi [Container: ASP.NET Core]" style="swimlane;html=1;whiteSpace=wrap;startSize=34;container=1;collapsible=0;rounded=1;fillColor=#FFFFFF;strokeColor=#2F3746;fontColor=#313A4C;fontStyle=1;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1"><mxGeometry x="320" y="130" width="650" height="470" as="geometry"/></mxCell>
        <mxCell id="controller" value="&lt;b&gt;SearchController&lt;/b&gt;&lt;br&gt;[Component: ASP.NET Controller]&lt;br&gt;&lt;br&gt;Modtager HTTP requests og returnerer responses" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="220" y="60" width="230" height="105" as="geometry"/></mxCell>
        <mxCell id="service" value="&lt;b&gt;SearchService&lt;/b&gt;&lt;br&gt;[Component: Application service]&lt;br&gt;&lt;br&gt;Orkestrerer validering, cache, søgelogik og mapping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="205" y="200" width="260" height="110" as="geometry"/></mxCell>
        <mxCell id="validator" value="&lt;b&gt;RequestValidator&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Validerer og normaliserer input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="35" y="345" width="180" height="85" as="geometry"/></mxCell>
        <mxCell id="repo" value="&lt;b&gt;DBRepository&lt;/b&gt;&lt;br&gt;[Component: Data access]&lt;br&gt;&lt;br&gt;Læser dokumenter og reverse index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="250" y="345" width="185" height="85" as="geometry"/></mxCell>
        <mxCell id="mapper" value="&lt;b&gt;DTO / Mapper&lt;/b&gt;&lt;br&gt;[Component]&lt;br&gt;&lt;br&gt;Mapper interne data til SearchResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2F72AF;fontColor=#FFFFFF;fontSize=11;arcSize=8;spacing=6;" vertex="1" parent="apiBoundary"><mxGeometry x="470" y="345" width="150" height="85" as="geometry"/></mxCell>
        <mxCell id="db2" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;[Container]&lt;br&gt;&lt;br&gt;Søgedata og index" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#2D8C7B;strokeColor=#1D5E53;fontColor=#FFFFFF;fontSize=11;spacing=6;" vertex="1" parent="1"><mxGeometry x="555" y="650" width="180" height="95" as="geometry"/></mxCell>
        <mxCell id="compNote" value="Component-diagrammet viser kun indersiden af SearchApi. Det forklarer, hvordan et søgekald går fra controlleren til en application service, videre gennem validering/dataadgang/mapping og ender som et SearchResult. Database og klient er vist udenfor containeren, fordi de ikke er interne komponenter i SearchApi." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=10;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="390" height="150" as="geometry"/></mxCell>
        <mxCell id="ce1" value="HTTP /api/search" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="client" target="controller"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce2" value="kalder" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="controller" target="service"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce3" value="validerer" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="service" target="validator"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce4" value="henter data" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="service" target="repo"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce5" value="mapper response" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="apiBoundary" source="service" target="mapper"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce6" value="SQL" style="endArrow=block;endFill=1;html=1;rounded=0;strokeWidth=2;strokeColor=#6B7280;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="repo" target="db2"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
