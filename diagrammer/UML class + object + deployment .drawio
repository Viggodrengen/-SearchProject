        <mxCell id="tfXAg9N1xq1Fkde9j8Ck-168" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=13" value="Diagrammet viser udviklingsmiljøet, som køres med Docker Compose på en lokal maskine. Browseren ligger udenfor miljøet, fordi den ikke startes af Docker Compose; den bruges kun til at tilgå SearchWebApp.&lt;br/&gt;&lt;br/&gt;Flowet går fra browseren ind i SearchWebApp. SearchWebApp kalder SearchLoadBalancer, og load balanceren fordeler søgninger videre til SearchApi. Her er SearchApi vist med to replikaer, A og B. Det er x-akse skalering: samme API kan køre i flere instanser, hvis flere brugere eller mere trafik skal håndteres.&lt;br/&gt;&lt;br/&gt;Til højre ligger runtime-komponenterne. I dette dev deployment bruges PostgreSQL som persistent database og Redis som cache til midlertidige søgeresultater. For at holde diagrammet læsbart viser vi kun én repræsentativ SQL-forbindelse og én repræsentativ cache-forbindelse, selvom begge API-instanser i praksis kan bruge begge komponenter.&lt;br/&gt;&lt;br/&gt;Nederst ligger observability. SearchLoadBalancer og SearchApi sender logs til Loki, og Grafana læser fra Loki for at visualisere drift og fejlsøgning." vertex="1">
          <mxGeometry height="190" width="1080" x="1026.996666666667" y="1898" as="geometry" />
        </mxCell>
        <mxCell id="tfXAg9N1xq1Fkde9j8Ck-169" edge="1" parent="1" source="tfXAg9N1xq1Fkde9j8Ck-145" style="endArrow=open;html=1;rounded=0;strokeWidth=2" target="tfXAg9N1xq1Fkde9j8Ck-148" value="HTTP">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
